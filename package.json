{
  "name": "mizu-hr",
  "devDependencies": {
    "@biomejs/biome": "https://pkg.pr.new/@biomejs/biome@7248dda",
    "@total-typescript/ts-reset": "^0.6.1",
    "turbo": "^2.5.6",
    "ultracite": "^5.2.5"
  },
  "packageManager": "bun@1.2.19",
  "private": true,
  "scripts": {
    "check": "biome check --write .",
    "dev": "turbo dev db:studio --parallel",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:api": "turbo -F api dev",
    "db:push": "turbo -F api db:push",
    "db:studio": "turbo -F api db:studio",
    "db:generate": "turbo -F api db:generate",
    "db:migrate": "turbo -F api db:migrate",
    "db:start": "turbo -F api db:start",
    "db:watch": "turbo -F api db:watch",
    "db:stop": "turbo -F api db:stop",
    "db:down": "turbo -F api db:down"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
