{
  "name": "api",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "typecheck": "tsc -b",
    "dev": "bun run --hot src/index.ts",
    "email": "email dev -d src/emails -p 5000",
    "start": "bun run dist/index.js",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "db:push": "bunx --bun drizzle-kit push",
    "db:studio": "bunx --bun drizzle-kit studio",
    "db:generate": "bunx --bun drizzle-kit generate",
    "db:migrate": "bunx --bun drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@orpc/server": "^1.13.4",
    "@polar-sh/better-auth": "^1.6.4",
    "@polar-sh/sdk": "^0.42.5",
    "@react-email/components": "^1.0.6",
    "better-auth": "^1.4.18",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^1.0.0-beta.9-e89174b",
    "hono": "^4.11.7",
    "hono-rate-limiter": "^0.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-email": "^5.2.5",
    "resend": "^6.9.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.2.5",
    "@types/bun": "^1.3.7",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^1.0.0-beta.9-e89174b",
    "typescript": "^5.9.3"
  }
}
