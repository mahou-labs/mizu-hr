{
  "name": "api",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile api",
    "dev": "vite dev --port=3000",
    "start": "wrangler dev",
    "deploy": "wrangler deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@orpc/client": "^1.5.0",
    "@orpc/server": "^1.5.0",
    "@polar-sh/better-auth": "^1.1.0",
    "@polar-sh/sdk": "^0.34.9",
    "better-auth": "^1.3.4",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.2",
    "pg": "^8.14.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.11.2",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.31.2",
    "tsdown": "^0.12.9",
    "typescript": "^5.8.2",
    "vite": "^7.0.6",
    "wrangler": "^4.23.0"
  }
}
