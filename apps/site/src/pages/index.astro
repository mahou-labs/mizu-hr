---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="flex items-center justify-center min-h-screen px-4 py-8 sm:py-16 relative z-10"
  >
    <div class="text-center w-full max-w-2xl">
      <p class="text-sm sm:text-base font-medium text-blue-600 dark:text-blue-400 mb-4 tracking-wide uppercase">
        Coming Soon
      </p>
      <h1
        class="text-4xl sm:text-5xl lg:text-6xl font-semibold leading-tight mb-12 sm:mb-16 tracking-tight"
      >
        The future of hiring is open source
      </h1>

      <div id="waitlist-container">
        <form id="waitlist-form" class="mt-8">
          <div class="flex flex-col sm:flex-row gap-3 mb-4 sm:items-center">
            <input
              type="email"
              id="email-input"
              name="email"
              placeholder="Enter your email"
              required
              class="flex-1 px-4 py-3.5 sm:px-5 sm:py-4 text-base sm:text-lg rounded-xl border-2 border-gray-300 bg-gray-50 text-gray-900 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 transition-all outline-none focus:border-blue-600 focus:shadow-[0_0_0_3px_rgba(59,130,246,0.1)] disabled:opacity-50 disabled:cursor-not-allowed"
              aria-label="Email address"
            />
            <button
              type="submit"
              id="submit-button"
              class="px-4 py-3.5 sm:px-8 sm:py-4 text-base sm:text-lg font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-xl border-none cursor-pointer transition-all outline-none hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(59,130,246,0.3)] focus:shadow-[0_0_0_3px_rgba(59,130,246,0.3)] sm:flex-shrink-0 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
            >
              Get Notified
            </button>
          </div>
          <p class="mt-4 text-sm opacity-70 leading-relaxed">
            Be the first to know when Mizu HR launches. No spam, just updates.
          </p>
        </form>
        <div id="success-message" class="hidden mt-8">
          <div
            class="px-6 py-4 text-base sm:text-lg rounded-xl bg-green-50 dark:bg-green-900/20 text-green-800 dark:text-green-200 border-2 border-green-200 dark:border-green-800"
          >
            <p class="font-medium mb-1">✓ You're on the list!</p>
            <p class="text-sm opacity-80">
              We'll notify you when Mizu HR launches.
            </p>
          </div>
        </div>
      </div>

      <div class="flex items-center justify-center gap-6 mt-12">
        <a
          href="https://github.com/mahou-labs/mizu-hr"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity"
          aria-label="GitHub"
        >
          <svg class="w-6 h-6" viewBox="0 0 32 32" fill="currentColor">
            <path d="M16 2C8.27 2 2 8.27 2 16c0 6.19 4.01 11.44 9.58 13.29.7.13.96-.3.96-.67 0-.33-.01-1.42-.02-2.58-3.9.85-4.72-1.65-4.72-1.65-.64-1.62-1.56-2.05-1.56-2.05-1.27-.87.1-.85.1-.85 1.4.1 2.14 1.44 2.14 1.44 1.25 2.14 3.28 1.52 4.08 1.16.13-.91.49-1.52.89-1.87-3.11-.35-6.38-1.56-6.38-6.93 0-1.53.55-2.78 1.44-3.76-.14-.36-.62-1.78.14-3.71 0 0 1.18-.38 3.85 1.44a13.4 13.4 0 0 1 7.02 0c2.67-1.82 3.85-1.44 3.85-1.44.76 1.93.28 3.35.14 3.71.9.98 1.44 2.23 1.44 3.76 0 5.38-3.28 6.57-6.4 6.92.5.43.95 1.29.95 2.6 0 1.87-.02 3.38-.02 3.84 0 .37.25.81.96.67C25.99 27.44 30 22.19 30 16c0-7.73-6.27-14-14-14z"/>
          </svg>
        </a>
        <a
          href="https://x.com/nchartiot"
          target="_blank"
          rel="noopener noreferrer"
          class="opacity-50 hover:opacity-100 transition-opacity"
          aria-label="X (Twitter)"
        >
          <svg class="w-6 h-6" viewBox="0 0 32 32" fill="currentColor">
            <path d="M18.42 14.71 27.9 4h-2.25l-8.23 9.3L10.6 4H3.24l9.94 14.06L3.24 28h2.25l8.69-9.82L21.4 28h7.36l-10.34-13.29Zm-3.08 3.48-.99-1.42L6.3 5.63h3.42l6.4 9.16 1.01 1.42 8.32 11.9h-3.42l-6.69-9.92Z"/>
          </svg>
        </a>
      </div>
    </div>
  </main>

  <script>
    import { orpc } from "../utils/orpc-client";

    declare global {
      interface Window {
        posthog?: { capture: (event: string, properties?: Record<string, unknown>) => void };
      }
    }

    const form = document.getElementById("waitlist-form") as HTMLFormElement;
    const emailInput = document.getElementById(
      "email-input",
    ) as HTMLInputElement;
    const submitButton = document.getElementById(
      "submit-button",
    ) as HTMLButtonElement;
    const successMessage = document.getElementById(
      "success-message",
    ) as HTMLDivElement;

    emailInput.addEventListener(
      "focus",
      () => {
        window.posthog?.capture("waitlist_attempt");
      },
      { once: true },
    );

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = emailInput.value;
      submitButton.disabled = true;
      emailInput.disabled = true;
      submitButton.textContent = "Submitting...";

      try {
        await orpc.waitlist.addEmail({ email });
        window.posthog?.capture("waitlist_success");
        form.classList.add("hidden");
        successMessage.classList.remove("hidden");
      } catch (error) {
        console.error("Failed to add email to waitlist:", error);
        submitButton.disabled = false;
        emailInput.disabled = false;
        submitButton.textContent = "Get Notified";
        alert("Something went wrong, please try again later.");
      }
    });
  </script>
</Layout>
