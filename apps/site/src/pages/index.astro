---
import ParticleBackground from "../components/ParticleBackground.tsx";
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<ParticleBackground client:load />
	<main class="flex items-center justify-center min-h-screen px-4 py-8 sm:py-16 relative z-10">
		<div class="text-center w-full max-w-2xl">
			<h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold leading-tight mb-12 sm:mb-16 tracking-tight pixelated-text">
				The future of hiring is open source
			</h1>
			
			<form class="mt-8" method="POST" action="/api/subscribe">
				<div class="flex flex-col sm:flex-row gap-3 mb-4 sm:items-center">
					<input 
						type="email" 
						name="email" 
						placeholder="Enter your email" 
						required 
						class="flex-1 px-4 py-3.5 sm:px-5 sm:py-4 text-base sm:text-lg rounded-xl border-2 border-gray-300 bg-gray-50 text-gray-900 dark:border-slate-600 dark:bg-slate-800 dark:text-slate-100 transition-all outline-none focus:border-blue-600 focus:shadow-[0_0_0_3px_rgba(59,130,246,0.1)]"
						aria-label="Email address"
					/>
					<button type="submit" class="px-4 py-3.5 sm:px-8 sm:py-4 text-base sm:text-lg font-medium text-white bg-blue-600 hover:bg-blue-700 rounded-xl border-none cursor-pointer transition-all outline-none hover:-translate-y-px hover:shadow-[0_4px_12px_rgba(59,130,246,0.3)] focus:shadow-[0_0_0_3px_rgba(59,130,246,0.3)] sm:flex-shrink-0">
						Get Notified
					</button>
				</div>
				<p class="mt-4 text-sm opacity-70 leading-relaxed">
					Be the first to know when Mizu HR launches. No spam, just updates.
				</p>
			</form>
		</div>
	</main>
</Layout>
