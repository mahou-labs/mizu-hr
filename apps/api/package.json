{
  "name": "api",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "email": "email dev -d src/emails -p 5000",
    "start": "bun run --bun db:push && bun run --bun dist/index.js",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@orpc/client": "^1.9.0",
    "@orpc/server": "^1.9.0",
    "@polar-sh/better-auth": "^1.1.4",
    "@polar-sh/sdk": "^0.35.2",
    "@react-email/components": "^0.5.5",
    "better-auth": "^1.3.18",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "hono": "^4.9.8",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-email": "^4.2.11",
    "resend": "^6.1.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.0-canary.20250921T171445"
  },
  "devDependencies": {
    "@react-email/preview-server": "^4.2.11",
    "@types/bun": "^1.2.22",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "drizzle-kit": "^0.31.4",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.2"
  }
}
