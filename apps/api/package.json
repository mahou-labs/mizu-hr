{
  "name": "api",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "check-types": "tsc -b",
    "dev": "bun run --hot src/index.ts",
    "email": "email dev -d src/emails -p 5000",
    "start": "bun run dist/index.js",
    "lint": "oxlint --type-aware",
    "format": "oxfmt",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@orpc/server": "^1.13.0",
    "@polar-sh/better-auth": "^1.6.3",
    "@polar-sh/sdk": "^0.41.5",
    "@react-email/components": "^1.0.2",
    "better-auth": "^1.4.7",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.11.1",
    "hono-rate-limiter": "^0.4.2",
    "pg": "^8.16.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-email": "^5.1.0",
    "resend": "^6.6.0",
    "uuid": "^13.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@react-email/preview-server": "^5.1.0",
    "@types/bun": "^1.3.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.9.3"
  }
}
